Cell[CellGroupData[{
Cell["SU(3) Yang-Mills vertex: LSH formulation", "Title",
 CellChangeTimes->{{3.974664165336544*^9, 
  3.974664190090613*^9}},ExpressionUUID->"d7e7d7da-e0e3-4eca-9ef1-\
deae917ecb63"],

Cell["\<\
Supplemental Material to \[OpenCurlyDoubleQuote]Loop-string-hadron approach \
to SU(3) lattice Yang-Mills theory, II: Operator representation for the \
trivalent vertex\[CloseCurlyDoubleQuote] (arXiv:2512.11796)\
\>", "Subtitle",
 CellChangeTimes->{{3.948384245099462*^9, 3.948384328279367*^9}, {
  3.948384581073828*^9, 3.948384581490157*^9}, {3.948389817783405*^9, 
  3.948389818462869*^9}, {3.974664245196726*^9, 3.974664252379157*^9}, {
  3.974786155084149*^9, 
  3.974786177761641*^9}},ExpressionUUID->"d1ac4594-b70d-4736-854b-\
66b9570e7436"],

Cell["\<\
Saurabh V. Kadam, Aahiri Naskar, Indrakshi Raychowdhury, and Jesse R. Stryker\
\
\>", "Author",
 CellChangeTimes->{{3.948384550808639*^9, 
  3.948384576094126*^9}},ExpressionUUID->"86e20937-5460-4893-b401-\
fad1dd45ad77"],

Cell["\<\
This notebook is a toolkit for explicit Hilbert-space calculations using \
loop-string-hadron (LSH) operators and states in the naive nonorthogonal \
basis. It is a companion software to the Part II article on \
\[OpenCurlyDoubleQuote]Loop-string-hadron approach to SU(3) lattice \
Yang-Mills theory\[CloseCurlyDoubleQuote]. The primary objects worked with \
are States (kets), and the operators are functions of those States. This \
script is specially tailored to the use of the nonorthogonal (but linearly \
independent) basis.

A similar notebook was released with Part I (arXiv:2407.19181) that relied on \
the Schwinger-boson formulation and its occupation-number basis.\
\>", "Abstract",
 CellChangeTimes->{{3.974664303521434*^9, 3.9746643155216227`*^9}, {
  3.974786282412*^9, 3.9747863917643003`*^9}, {3.974786431505353*^9, 
  3.974786459600431*^9}, {3.974786496930164*^9, 3.974786696505199*^9}, {
  3.974786744433452*^9, 3.974786769136222*^9}, {3.974787665182103*^9, 
  3.974787751784568*^9}, {3.9747877854429216`*^9, 
  3.9747878001334047`*^9}},ExpressionUUID->"df65c082-0ef0-4b1d-a69f-\
dd48a0fff4ad"],

Cell["\<\
Please forward any errata to Jesse Stryker or any of the authors.\
\>", "Text",
 CellChangeTimes->{{3.974664981268016*^9, 3.974665043079766*^9}, {
  3.974665075562365*^9, 3.974665108441879*^9}, {3.974665144703817*^9, 
  3.9746651456075287`*^9}, {3.974786801872632*^9, 3.974786809455742*^9}, {
  3.974787070029513*^9, 
  3.9747870725042753`*^9}},ExpressionUUID->"8e2f9587-54bb-4967-a01f-\
ab7bd488045d"],

Cell["\<\
March 2026 updates: \[LineSeparator]- Notebook was updated to make more use \
of the J^\\dagger, K^\\dagger, J, and K corner operators. The same operators \
have been hard-coded to match the presentation in the manuscript. Functions \
referring to irreducible Schwinger boson contractions that were previously \
hard-coded are now expressed in terms of LSH operators.
- Added a new section for confirming the commutator identities found in Sec. \
III A of arXiv:2512.11796v2.
- Variables within functions have been updated to better match the notation \
used in the (v2) manuscript.\
\>", "Text",
 CellChangeTimes->{{3.980447928449959*^9, 3.98044839462495*^9}, {
  3.980525801022875*^9, 3.980525833485867*^9}, {3.9805258664868298`*^9, 
  3.98052587693359*^9}, {3.981834087685459*^9, 
  3.9818341883951178`*^9}},ExpressionUUID->"ddf56938-2c36-4a34-8880-\
e656c61c2a52"],

