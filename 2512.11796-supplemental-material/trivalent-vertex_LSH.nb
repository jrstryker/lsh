 RowBox[{
  RowBox[{"PQSectorDim", "[", "PQPQPQ_", "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Given", " ", "all", " ", "six", " ", "irrep", " ", "quantum", " ", 
     "numbers", " ", "at", " ", "the", " ", "vertex"}], ",", 
    RowBox[{
     RowBox[{
     "evaluates", " ", "the", " ", "dimensionality", " ", "of", " ", "this", 
      " ", "subspace", " ", "using", " ", "an", " ", "LSH"}], "-", 
     RowBox[{"inspired", " ", 
      RowBox[{"technique", "."}]}]}]}], " ", "*)"}], "\n", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "tt", ",", "PP1", ",", "QQ1", ",", "PP2", ",", "QQ2", ",", "PP3", ",", 
      "QQ3", ",", "pp1", ",", "qq1", ",", "pp2", ",", "qq2", ",", "pp3", ",", 
      "qq3", ",", "l31UpperLim", ",", "l31LowerLim"}], "}"}], ",", "\n", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "PP1", ",", "QQ1", ",", "PP2", ",", "QQ2", ",", "PP3", ",", "QQ3"}], 
       "}"}], "=", "PQPQPQ"}], ";", "\n", 
     RowBox[{"tt", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "3"}], ")"}], 
       RowBox[{"(", 
        RowBox[{
        "PP1", "+", "PP2", "+", "PP3", "-", "QQ1", "-", "QQ2", "-", "QQ3"}], 
        ")"}]}]}], ";", "\n", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"tt", "\[NotElement]", "Integers"}], ",", 
       RowBox[{"Return", "[", "0", "]"}]}], "]"}], ";", "\n", 
     RowBox[{"pp1", "=", 
      RowBox[{"PP1", "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "2"}], ")"}], 
        RowBox[{"(", 
         RowBox[{
