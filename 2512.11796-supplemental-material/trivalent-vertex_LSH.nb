Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"TermN", "[", 
    RowBox[{"ii_", ",", "jj_", ",", "term_"}], "]"}], ":=", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"takes", " ", "a", " ", "term"}], ",", " ", 
     RowBox[{"returns", " ", "a", " ", "STATE"}]}], " ", "*)"}], "\n", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "qNums", ",", "amp", ",", "kk", ",", "ell", ",", "lij", ",", "ljk", ",",
        "lki", ",", "lji", ",", "lkj", ",", "lik", ",", "tt", ",", 
       "\[Epsilon]ijk", ",", "\[Sigma]ij", ",", "\[Sigma]jk", ",", "outAmp1", 
       ",", "outQNums1", ",", "outAmp2", ",", "outQNums2"}], "}"}], ",", "\n", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"qNums", ",", "amp"}], "}"}], "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"term", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"term", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "}"}]}], ";", "\n", 
      RowBox[{"kk", "=", 
       RowBox[{"6", "-", "ii", "-", "jj"}]}], ";", "\n", "\n", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"ell", "[", 
          RowBox[{"1", ",", "2"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"2", ",", "3"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"3", ",", "1"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"2", ",", "1"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"3", ",", "2"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"1", ",", "3"}], "]"}], ",", "tt"}], "}"}], "=", "qNums"}], 
      ";", "\n", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "lij", ",", "ljk", ",", "lki", ",", "lji", ",", "lkj", ",", "lik"}], 
        "}"}], "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"ell", "[", 
          RowBox[{"ii", ",", "jj"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"jj", ",", "kk"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"kk", ",", "ii"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"jj", ",", "ii"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"kk", ",", "jj"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"ii", ",", "kk"}], "]"}]}], "}"}]}], ";", "\n", 
      RowBox[{"\[Epsilon]ijk", "=", 
       RowBox[{
        RowBox[{"LeviCivitaTensor", "[", "3", "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"ii", ",", "jj", ",", "kk"}], "]"}], "]"}]}], ";", "\n", 
      RowBox[{"\[Sigma]ij", "=", 
       RowBox[{"lij", "+", "lji"}]}], ";", "\n", 
      RowBox[{"\[Sigma]jk", "=", 
       RowBox[{"ljk", "+", "lkj"}]}], ";", "\[IndentingNewLine]", "\n", 
      RowBox[{"outQNums1", "=", 
       RowBox[{"qNums", "-", 
        RowBox[{"uVec", "[", 
         RowBox[{"jj", ",", "kk"}], "]"}], "+", 
        RowBox[{"uVec", "[", 
         RowBox[{"ii", ",", "kk"}], "]"}]}]}], ";", "\n", 
      RowBox[{"outQNums2", "=", 
       RowBox[{"qNums", "+", 
        RowBox[{"uVec", "[", 
         RowBox[{"ii", ",", "jj"}], "]"}], "+", 
        RowBox[{"uVec", "[", 
         RowBox[{"kk", ",", "ii"}], "]"}], "-", 
        RowBox[{"uVec", "[", 
         RowBox[{"jj", ",", "ii"}], "]"}], "-", 
        RowBox[{"uVec", "[", 
         RowBox[{"kk", ",", "jj"}], "]"}]}]}], ";", "\n", 
      RowBox[{"outAmp1", "=", 
       RowBox[{"amp", "*", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"ljk", "*", 
           RowBox[{"(", 
            RowBox[{"lji", "+", "\[Sigma]jk", "+", 
             RowBox[{"Abs", "[", "tt", "]"}], "+", "1"}], ")"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"\[Sigma]ij", "+", "\[Sigma]jk", "+", 
           RowBox[{"Abs", "[", "tt", "]"}], "+", "1"}], ")"}]}]}]}], ";", 
      "\n", 
      RowBox[{"outAmp2", "=", 
       RowBox[{"amp", "*", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "*", "lji", "*", "lkj"}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"\[Sigma]ij", "+", "\[Sigma]jk", "+", 
           RowBox[{"Abs", "[", "tt", "]"}], "+", "1"}], ")"}]}]}]}], ";", 
      "\n", "\n", 
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"outQNums1", ",", "outAmp1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"outQNums2", ",", "outAmp2"}], "}"}]}], "}"}], "]"}], 
      ";"}]}], "\n", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"TermN", "[", 
     RowBox[{"ii_", ",", "jj_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"TermN", "[", 
      RowBox[{"ii", ",", "jj", ",", "#"}], "]"}], "&"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
