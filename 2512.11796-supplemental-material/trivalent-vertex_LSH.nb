Cell[CellGroupData[{

Cell["Functions for overlaps and normalization", "Section",
 CellChangeTimes->{{3.974790373543771*^9, 3.974790375431704*^9}, {
  3.974790454790913*^9, 3.974790469234942*^9}, {3.9747925093714447`*^9, 
  3.9747925317745047`*^9}},ExpressionUUID->"67b4f834-df29-46b3-9f18-\
f75114c39d58"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"TermLSHOverlap", "[", 
     RowBox[{"term1_", ",", "term2_"}], "]"}], ":=", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
       "Computes", " ", "overlap", " ", "of", " ", "two", " ", "terms"}], " ",
        "<", "\[Alpha]"}], "|", 
      RowBox[{"\[Beta]", ">", " ", 
       RowBox[{
       "by", " ", "applying", " ", "the", " ", "lowering", " ", "operators", 
        " ", "\n", "from", " ", "the", " ", "bra"}], " ", "<", "\[Alpha]"}], 
      "|", " ", 
      RowBox[{
      "on", " ", "the", " ", "left", " ", "to", " ", "the", " ", "ket"}], " ",
       "|", 
      RowBox[{"\[Beta]", ">", " ", 
       RowBox[{"on", " ", "the", " ", 
        RowBox[{"right", ".", "\n", "Zero"}], " ", "is", " ", "automatically",
         " ", "returned", " ", "if"}]}], " ", "|", 
      RowBox[{"\[Alpha]", ">", " ", "and"}], " ", "|", 
      RowBox[{"\[Beta]", ">", " ", 
       RowBox[{
       "are", " ", "terms", " ", "from", " ", "different", " ", "PQPQPQ", " ", 
        RowBox[{"sectors", "."}]}]}]}], "*)"}], "\n", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "qNums1", ",", "amp1", ",", "amp2", ",", "pqVec1", ",", "pqVec2", ",", 
        "ells1", ",", "tt1", ",", "ells2", ",", "tt2", ",", "loweredState", 
        ",", "scvAmplitude"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"qNums1", ",", "amp1"}], "}"}], "=", "term1"}], ";", "\n", 
       RowBox[{"amp2", "=", 
        RowBox[{"term2", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\n", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"pqVec1", ",", "pqVec2"}], "}"}], "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"TermGetPQList", "[", "term1", "]"}], ",", 
          RowBox[{"TermGetPQList", "[", "term2", "]"}]}], "}"}]}], ";", "\n", 
       
       RowBox[{"Return", "[", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"pqVec1", "==", "pqVec2"}], "&&", 
           RowBox[{"amp1", "!=", "0"}], "&&", 
           RowBox[{"amp2", "!=", "0"}]}], ",", "\n", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"ells1", "[", 
               RowBox[{"1", ",", "2"}], "]"}], ",", 
              RowBox[{"ells1", "[", 
               RowBox[{"2", ",", "3"}], "]"}], ",", 
              RowBox[{"ells1", "[", 
               RowBox[{"3", ",", "1"}], "]"}], ",", 
              RowBox[{"ells1", "[", 
               RowBox[{"2", ",", "1"}], "]"}], ",", 
              RowBox[{"ells1", "[", 
               RowBox[{"3", ",", "2"}], "]"}], ",", 
              RowBox[{"ells1", "[", 
               RowBox[{"1", ",", "3"}], "]"}], ",", "tt1"}], "}"}], "=", 
            RowBox[{"term1", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", 
           RowBox[{"loweredState", "=", 
            RowBox[{"{", "term2", "}"}]}], ";", "\n", 
           RowBox[{"loweredState", "=", 
            RowBox[{
             RowBox[{
              RowBox[{"loweredState", "//", 
               RowBox[{"StateApplyOp", "[", 
                RowBox[{
                 RowBox[{"StateL", "[", 
                  RowBox[{"1", ",", "2"}], "]"}], ",", 
                 RowBox[{"ells1", "[", 
                  RowBox[{"1", ",", "2"}], "]"}]}], "]"}]}], "//", 
              RowBox[{"StateApplyOp", "[", 
               RowBox[{
                RowBox[{"StateL", "[", 
                 RowBox[{"2", ",", "3"}], "]"}], ",", 
                RowBox[{"ells1", "[", 
                 RowBox[{"2", ",", "3"}], "]"}]}], "]"}]}], "//", 
             RowBox[{"StateApplyOp", "[", 
              RowBox[{
               RowBox[{"StateL", "[", 
                RowBox[{"3", ",", "1"}], "]"}], ",", 
               RowBox[{"ells1", "[", 
                RowBox[{"3", ",", "1"}], "]"}]}], "]"}]}]}], ";", "\n", 
           RowBox[{"loweredState", "=", 
            RowBox[{
             RowBox[{
              RowBox[{"loweredState", "//", 
               RowBox[{"StateApplyOp", "[", 
                RowBox[{
                 RowBox[{"StateL", "[", 
                  RowBox[{"2", ",", "1"}], "]"}], ",", 
                 RowBox[{"ells1", "[", 
                  RowBox[{"2", ",", "1"}], "]"}]}], "]"}]}], "//", 
              RowBox[{"StateApplyOp", "[", 
               RowBox[{
                RowBox[{"StateL", "[", 
                 RowBox[{"3", ",", "2"}], "]"}], ",", 
                RowBox[{"ells1", "[", 
                 RowBox[{"3", ",", "2"}], "]"}]}], "]"}]}], "//", 
             RowBox[{"StateApplyOp", "[", 
              RowBox[{
               RowBox[{"StateL", "[", 
                RowBox[{"1", ",", "3"}], "]"}], ",", 
               RowBox[{"ells1", "[", 
                RowBox[{"1", ",", "3"}], "]"}]}], "]"}]}]}], ";", "\n", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"tt1", ">=", "1"}], ",", 
             RowBox[{
              RowBox[{"loweredState", "=", 
               RowBox[{"loweredState", "//", 
                RowBox[{"StateApplyOp", "[", 
                 RowBox[{"StateTA", ",", "tt1"}], "]"}]}]}], ";"}]}], "]"}], 
           ";", "\n", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"tt1", "<=", 
              RowBox[{"-", "1"}]}], ",", 
             RowBox[{
              RowBox[{"loweredState", "=", 
               RowBox[{"loweredState", "//", 
                RowBox[{"StateApplyOp", "[", 
                 RowBox[{"StateTB", ",", 
                  RowBox[{"Abs", "[", "tt1", "]"}]}], "]"}]}]}], ";"}]}], 
            "]"}], ";", "\n", 
           RowBox[{"loweredState", "=", 
            RowBox[{"loweredState", "//", "StateConsolidateTerms"}]}], ";", 
           "\n", 
           RowBox[{"scvAmplitude", "=", 
            RowBox[{"StateGetAmplitude", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
               "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", 
                "0"}], "}"}], ",", "loweredState"}], "]"}]}], ";", "\n", 
           RowBox[{
            RowBox[{"Conjugate", "[", "amp1", "]"}], "*", "scvAmplitude"}]}], 
          "\n", ",", "0"}], "]"}], "\n", "]"}], ";"}]}], "\n", "]"}]}], ";"}],
   "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"StateLSHOverlap", "[", 
     RowBox[{"state1_", ",", "state2_"}], "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"c1", ",", "c2"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"c1", "=", 
        RowBox[{"state1", "//", "StateConsolidateTerms"}]}], ";", "\n", 
       RowBox[{"c2", "=", 
        RowBox[{"state2", "//", "StateConsolidateTerms"}]}], ";", "\n", 
       RowBox[{"Return", "[", 
        RowBox[{"Total", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"TermLSHOverlap", "[", 
             RowBox[{
              RowBox[{"c1", "[", 
               RowBox[{"[", "termI", "]"}], "]"}], ",", 
              RowBox[{"c2", "[", 
               RowBox[{"[", "termJ", "]"}], "]"}]}], "]"}], "\n", ",", 
            RowBox[{"{", 
             RowBox[{"termI", ",", 
              RowBox[{"Length", "[", "c1", "]"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"termJ", ",", 
              RowBox[{"Length", "[", "c2", "]"}]}], "}"}]}], "]"}], "//", 
          "Flatten"}], "]"}], "]"}]}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"StateLSHNorm", "[", "state_", "]"}], ":=", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"StateLSHOverlap", "[", 
      RowBox[{"state", ",", "state"}], "]"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"StateLSHNormalized", "[", "state_", "]"}], ":=", 
   RowBox[{"state", "//", 
    RowBox[{"StateScale", "[", 
     RowBox[{"1", "/", 
      RowBox[{"StateLSHNorm", "[", "state", "]"}]}], "]"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9747693624267077`*^9, 3.974769391795665*^9}, {
  3.9747826151004877`*^9, 3.974782641108596*^9}, {3.974794330168627*^9, 
  3.974794363221008*^9}, {3.974794397670151*^9, 3.974794402277301*^9}, {
  3.974794497142558*^9, 3.974794498088055*^9}, {3.974794530918763*^9, 
  3.974794531365761*^9}, {3.974794635692044*^9, 3.974794642492996*^9}},
 CellLabel->
  "In[1325]:=",ExpressionUUID->"3115b706-ee1a-4486-9c7d-fbcab97fe85c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SectorGetBasisTermQNums", "[", "PQPQPQ_", "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"PQSectorLSHRep", "[", "PQPQPQ", "]"}], "+", 
     RowBox[{"n", "*", "ellsShift"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "0", ",", 
      RowBox[{
       RowBox[{"PQSectorDim", "[", "PQPQPQ", "]"}], "-", "1"}]}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SectorGetBasisStates", "[", "PQPQPQ_", "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", "basisTermQNums", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"basisTermQNums", "=", 
       RowBox[{"SectorGetBasisTermQNums", "[", "PQPQPQ", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", " ", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"basisTermQNums", "[", 
             RowBox[{"[", "n", "]"}], "]"}], ",", "1"}], "}"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", "1", ",", 
           RowBox[{"Length", "[", "basisTermQNums", "]"}]}], "}"}]}], "]"}], 
       "]"}], ";"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SectorGetOverlapMatrix", "[", "PQPQPQ_", "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", "basisStates", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"basisStates", "=", 
       RowBox[{"SectorGetBasisStates", "[", "PQPQPQ", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"StateLSHOverlap", "[", 
          RowBox[{
           RowBox[{"basisStates", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", 
           RowBox[{"basisStates", "[", 
            RowBox[{"[", "j", "]"}], "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "basisStates", "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"Length", "[", "basisStates", "]"}]}], "}"}]}], "]"}], 
       "]"}], ";"}]}], "\[IndentingNewLine]", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.974779732222416*^9, 3.974779784804439*^9}, {
  3.974779907723487*^9, 3.974779959067514*^9}, {3.974780851692219*^9, 
  3.974781024471683*^9}, {3.974781110581315*^9, 3.974781112919216*^9}, {
  3.974781208007474*^9, 3.974781234150773*^9}, {3.974781285831694*^9, 
  3.974781444842292*^9}, {3.974781498977695*^9, 3.97478150414927*^9}, {
  3.97478160738393*^9, 3.974781611185893*^9}, {3.974782110914898*^9, 
  3.974782111363548*^9}},
 CellLabel->
  "In[1329]:=",ExpressionUUID->"ff8865a6-aeb1-44a3-89be-530a869f7493"],

Cell["Some formatting functions:", "Text",
 CellChangeTimes->{{3.9747935371480083`*^9, 
  3.974793541807261*^9}},ExpressionUUID->"10129054-c83d-44b7-8a01-\
4e8d267e30ab"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"NormalizeByLargest", "[", "vec_", "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"Max", "[", 
       RowBox[{"Abs", "[", "vec", "]"}], "]"}], "^", 
      RowBox[{"-", "1"}]}], " ", "vec"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"MakeFirstOnePositive", "[", "nums_", "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "simpNums", ",", "negOnePositions", ",", "posOnePositions", ",", 
        "firstNegOne", ",", "firstPosOne"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"simpNums", "=", 
        RowBox[{"Simplify", "[", "nums", "]"}]}], ";", "\n", 
       RowBox[{"negOnePositions", "=", 
        RowBox[{"Position", "[", 
         RowBox[{"simpNums", ",", 
          RowBox[{"-", "1"}]}], "]"}]}], ";", "\n", 
       RowBox[{"posOnePositions", "=", 
        RowBox[{"Position", "[", 
         RowBox[{"simpNums", ",", "1"}], "]"}]}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "negOnePositions", "]"}], "==", "0"}], ",", 
         RowBox[{"Return", "[", "simpNums", "]"}]}], "]"}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "negOnePositions", "]"}], ">", "0"}], " ", "&&",
           " ", 
          RowBox[{
           RowBox[{"Length", "[", "posOnePositions", "]"}], "==", "0"}]}], 
         ",", 
         RowBox[{"Return", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "*", "simpNums"}], "]"}]}], "]"}], ";",
        "\n", 
       RowBox[{"firstNegOne", "=", 
        RowBox[{"negOnePositions", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", 
       RowBox[{"firstPosOne", "=", 
        RowBox[{"posOnePositions", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", 
       RowBox[{"Return", "[", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"firstPosOne", ",", "firstNegOne"}], "}"}], "==", 
           RowBox[{"Sort", "[", 
            RowBox[{"{", 
             RowBox[{"firstPosOne", ",", "firstNegOne"}], "}"}], "]"}]}], ",",
           "simpNums", ",", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "*", "simpNums"}]}], "]"}], "]"}], 
       ";"}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"FormattedEigensystem", "[", "mat_", "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Eigenvalues", "[", "mat", "]"}], "//", "Reverse"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Eigenvectors", "[", "mat", "]"}], "//", "Reverse"}], "//", 
       RowBox[{"Map", "[", "NormalizeByLargest", "]"}]}], "//", 
      RowBox[{"Map", "[", "MakeFirstOnePositive", "]"}]}]}], "}"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.974793168328672*^9, 3.974793168967705*^9}},
 CellLabel->
  "In[1332]:=",ExpressionUUID->"d2e5684f-79aa-45ef-b3bb-2f7cc51618aa"]
}, Open  ]],

