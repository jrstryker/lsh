   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"takes", " ", "a", " ", "term"}], ",", " ", 
     RowBox[{"returns", " ", "a", " ", "STATE"}]}], " ", "*)"}], "\n", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", "\n", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ii", "==", "jj"}], " ", "&&", " ", 
         RowBox[{"SubsetQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", "2", ",", "3"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"ii", ",", "jj", ",", "kk"}], "}"}]}], "]"}]}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"{", "}"}], "]"}]}], "]"}], ";", "\n", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"kk", "==", "jj"}], " ", "&&", " ", 
         RowBox[{"SubsetQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", "2", ",", "3"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"ii", ",", "jj", ",", "kk"}], "}"}]}], "]"}]}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"TermJDag", "[", 
          RowBox[{"ii", ",", "jj", ",", "term"}], "]"}], "]"}]}], "]"}], ";", 
      "\n", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"kk", "==", "ii"}], " ", "&&", " ", 
         RowBox[{"SubsetQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", "2", ",", "3"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"ii", ",", "jj", ",", "kk"}], "}"}]}], "]"}]}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"TermJDag", "[", 
          RowBox[{"jj", ",", "ii", ",", 
           RowBox[{"TermScale", "[", 
            RowBox[{
             RowBox[{"-", "1"}], ",", "term"}], "]"}]}], "]"}], "]"}]}], 
       "]"}], ";", "\n", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Sort", "[", 
          RowBox[{"{", 
