   RowBox[{"StateN", "[", 
    RowBox[{"ii_", ",", "jj_", ",", "state_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{"TermN", "[", 
       RowBox[{"ii", ",", "jj"}], "]"}], ",", "state"}], "]"}], "//", 
    RowBox[{
     RowBox[{"Flatten", "[", 
      RowBox[{"#", ",", "1"}], "]"}], "&"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"StateN", "[", 
    RowBox[{"ii_", ",", "jj_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"StateN", "[", 
     RowBox[{"ii", ",", "jj", ",", "#"}], "]"}], "&"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.980435331163677*^9, 3.980435338608182*^9}, {
   3.980437205837778*^9, 3.980437274140527*^9}, 3.980437392218258*^9, {
   3.9804374256360693`*^9, 3.980437436034739*^9}, {3.980437471539018*^9, 
