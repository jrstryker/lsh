      RowBox[{"i", ",", "j"}], "]"}], ",", 
     RowBox[{"StateLDag", "[", 
      RowBox[{"j", ",", 
       RowBox[{"6", "-", "i", "-", "j"}]}], "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
