Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"lhsLA", "[", 
    RowBox[{"i_", ",", "j_"}], "]"}], ":=", 
   RowBox[{"StateCommutator", "[", 
    RowBox[{
     RowBox[{"StateL", "[", 
      RowBox[{"i", ",", "j"}], "]"}], ",", 
     RowBox[{"StateLDag", "[", 
      RowBox[{"i", ",", "j"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"lhsLB", "[", 
