Cell[CellGroupData[{

Cell["4. Applications of the formulas", "Chapter",
 CellChangeTimes->{{3.974789032063813*^9, 3.974789041197117*^9}, {
  3.974789480609602*^9, 3.974789482042579*^9}, {3.97479032267022*^9, 
  3.974790323297283*^9}, {3.974790364204211*^9, 3.974790366027463*^9}, {
  3.9747926055083513`*^9, 3.974792610344925*^9}, {3.981835193120977*^9, 
