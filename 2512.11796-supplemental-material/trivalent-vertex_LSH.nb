Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"TermJDag", "[", 
    RowBox[{"ii_", ",", "jj_", ",", "term_"}], "]"}], ":=", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"takes", " ", "a", " ", "term"}], ",", " ", 
     RowBox[{"returns", " ", "a", " ", "STATE"}]}], " ", "*)"}], "\n", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "qNums", ",", "amp", ",", "kk", ",", "ell", ",", "lij", ",", "ljk", ",",
        "lki", ",", "lji", ",", "lkj", ",", "lik", ",", "tt", ",", 
       "\[Epsilon]ijk", ",", "nonNegResult", ",", "negResult"}], "}"}], ",", 
     "\n", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"ii", "==", "jj"}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"{", "}"}], "]"}]}], "]"}], ";", "\n", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"qNums", ",", "amp"}], "}"}], "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"term", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"term", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "}"}]}], ";", "\n", 
      RowBox[{"kk", "=", 
       RowBox[{"6", "-", "ii", "-", "jj"}]}], ";", "\n", "\n", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"ell", "[", 
          RowBox[{"1", ",", "2"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"2", ",", "3"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"3", ",", "1"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"2", ",", "1"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"3", ",", "2"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"1", ",", "3"}], "]"}], ",", "tt"}], "}"}], "=", "qNums"}], 
      ";", "\n", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "lij", ",", "ljk", ",", "lki", ",", "lji", ",", "lkj", ",", "lik"}], 
        "}"}], "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"ell", "[", 
          RowBox[{"ii", ",", "jj"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"jj", ",", "kk"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"kk", ",", "ii"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"jj", ",", "ii"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"kk", ",", "jj"}], "]"}], ",", 
         RowBox[{"ell", "[", 
          RowBox[{"ii", ",", "kk"}], "]"}]}], "}"}]}], ";", "\n", 
      RowBox[{"\[Epsilon]ijk", "=", 
       RowBox[{
        RowBox[{"LeviCivitaTensor", "[", "3", "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"ii", ",", "jj", ",", "kk"}], "]"}], "]"}]}], ";", "\n", 
      "\n", 
      RowBox[{"nonNegResult", "=", 
       RowBox[{"{", "\n", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"qNums", "+", 
           RowBox[{"uVec", "[", "7", "]"}], "-", 
           RowBox[{"uVec", "[", 
            RowBox[{"kk", ",", "jj"}], "]"}]}], ",", 
          RowBox[{"amp", "*", "\[Epsilon]ijk", "*", "lkj"}]}], "}"}], "}"}]}],
       ";", "\n", 
      RowBox[{"negResult", "=", 
       RowBox[{"{", "\n", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"qNums", "+", 
            RowBox[{"uVec", "[", "7", "]"}], "+", 
            RowBox[{"uVec", "[", 
             RowBox[{"jj", ",", "ii"}], "]"}], "+", 
            RowBox[{"uVec", "[", 
             RowBox[{"ii", ",", "kk"}], "]"}]}], ",", 
           RowBox[{"amp", "*", "\[Epsilon]ijk", "*", 
            RowBox[{"(", 
             RowBox[{"lkj", "+", 
              RowBox[{"Abs", "[", "tt", "]"}]}], ")"}]}]}], "}"}], ",", "\n", 
         
         RowBox[{"{", 
          RowBox[{
           RowBox[{"qNums", "+", 
            RowBox[{"uVec", "[", "7", "]"}], "+", 
            RowBox[{"uVec", "[", 
             RowBox[{"ii", ",", "jj"}], "]"}], "+", 
            RowBox[{"uVec", "[", 
             RowBox[{"jj", ",", "kk"}], "]"}], "+", 
            RowBox[{"uVec", "[", 
             RowBox[{"kk", ",", "ii"}], "]"}], "-", 
            RowBox[{"uVec", "[", 
             RowBox[{"kk", ",", "jj"}], "]"}]}], ",", 
           RowBox[{"amp", "*", "\[Epsilon]ijk", "*", "lkj"}]}], "}"}]}], 
        "}"}]}], ";", "\n", "\n", 
      RowBox[{"Return", "[", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"tt", ">=", "0"}], ",", 
         RowBox[{"Evaluate", "[", "nonNegResult", "]"}], ",", 
         RowBox[{"Evaluate", "[", "negResult", "]"}]}], "]"}], "]"}], ";"}]}],
     "\n", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"TermJDag", "[", 
    RowBox[{"ii_", ",", "jj_"}], "]"}], ":=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"TermJDag", "[", 
      RowBox[{"ii", ",", "jj", ",", "#"}], "]"}], "&"}], ")"}]}], 
