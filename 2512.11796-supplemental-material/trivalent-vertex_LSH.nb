          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "}"}], "&"}], ",", 
      "state"}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
