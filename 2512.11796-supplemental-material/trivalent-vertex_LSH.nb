Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PQSectorLSHRep", "[", "PQPQPQ_", "]"}], ":=", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Returns", " ", "the", " ", "LSH", " ", "quantum", " ", "numbers", " ", 
      "of", " ", "the", " ", "\"\<reference basis state\>\"", " ", "in", " ", 
      "a", " ", "given", " ", "PQPQPQ", " ", 
      RowBox[{"sector", ".", "The"}], " ", "\"\<reference\>\"", " ", "state", 
      " ", "is", " ", "the", " ", "one", " ", "where", " ", "min", 
      RowBox[{"(", 
       RowBox[{"l12", ",", "l23", ",", "l31"}], ")"}]}], "=", 
     RowBox[{
      RowBox[{
      "0.", " ", "The", " ", "other", " ", "states", " ", "are", " ", 
       "related", " ", "to", " ", "it", " ", "by", " ", 
       RowBox[{"(", 
        RowBox[{
        "l12", ",", "l23", ",", "l31", ",", "l21", ",", "l32", ",", "l13", 
         ",", "t"}], ")"}]}], "+", 
      RowBox[{"n", "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", ",", "1", ",", "1", ",", 
          RowBox[{"-", "1"}], ",", 
          RowBox[{"-", "1"}], ",", 
          RowBox[{"-", "1"}], ",", "0"}], ")"}], "."}]}]}]}], " ", "*)"}], 
   "\n", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "tt", ",", "PP1", ",", "QQ1", ",", "PP2", ",", "QQ2", ",", "PP3", ",", 
       "QQ3", ",", "pp1", ",", "qq1", ",", "pp2", ",", "qq2", ",", "pp3", ",",
        "qq3", ",", "l31UpperLim", ",", "l31LowerLim", ",", "ell"}], "}"}], 
     ",", "\n", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"PQSectorDim", "[", "PQPQPQ", "]"}], ">=", "1"}], ",", "\n", 
        
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "PP1", ",", "QQ1", ",", "PP2", ",", "QQ2", ",", "PP3", ",", 
            "QQ3"}], "}"}], "=", "PQPQPQ"}], ";", "\n", 
         RowBox[{"tt", "=", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", "3"}], ")"}], 
           RowBox[{"(", 
            RowBox[{
            "PP1", "+", "PP2", "+", "PP3", "-", "QQ1", "-", "QQ2", "-", 
             "QQ3"}], ")"}]}]}], ";", "\n", 
         RowBox[{"pp1", "=", 
          RowBox[{"PP1", "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "/", "2"}], ")"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Abs", "[", "tt", "]"}], "+", "tt"}], ")"}]}]}]}], ";", 
         "\n", 
         RowBox[{"pp2", "=", 
          RowBox[{"PP2", "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "/", "2"}], ")"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Abs", "[", "tt", "]"}], "+", "tt"}], ")"}]}]}]}], ";", 
         "\n", 
         RowBox[{"pp3", "=", 
          RowBox[{"PP3", "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "/", "2"}], ")"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Abs", "[", "tt", "]"}], "+", "tt"}], ")"}]}]}]}], ";", 
         "\n", 
         RowBox[{"qq1", "=", 
          RowBox[{"QQ1", "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "/", "2"}], ")"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Abs", "[", "tt", "]"}], "-", "tt"}], ")"}]}]}]}], ";", 
         "\n", 
         RowBox[{"qq2", "=", 
          RowBox[{"QQ2", "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "/", "2"}], ")"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Abs", "[", "tt", "]"}], "-", "tt"}], ")"}]}]}]}], ";", 
         "\n", 
         RowBox[{"qq3", "=", 
          RowBox[{"QQ3", "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "/", "2"}], ")"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Abs", "[", "tt", "]"}], "-", "tt"}], ")"}]}]}]}], ";", 
         "\n", 
         RowBox[{"l31UpperLim", "=", 
          RowBox[{"Min", "[", 
           RowBox[{"qq1", ",", "pp3", ",", 
            RowBox[{"pp1", "+", "pp3", "-", "qq2"}]}], "]"}]}], ";", "\n", 
         RowBox[{"l31LowerLim", "=", 
          RowBox[{"Max", "[", 
           RowBox[{
            RowBox[{"pp3", "-", "qq2"}], ",", 
            RowBox[{"qq1", "-", "pp2"}], ",", "0"}], "]"}]}], ";", "\n", 
         RowBox[{
          RowBox[{"ell", "[", 
           RowBox[{"3", ",", "1"}], "]"}], "=", "l31LowerLim"}], ";", "\n", 
         RowBox[{
          RowBox[{"ell", "[", 
           RowBox[{"1", ",", "2"}], "]"}], "=", 
          RowBox[{
           RowBox[{"ell", "[", 
            RowBox[{"3", ",", "1"}], "]"}], "-", "pp3", "+", "qq2"}]}], ";", 
         "\n", 
         RowBox[{
          RowBox[{"ell", "[", 
           RowBox[{"2", ",", "3"}], "]"}], "=", 
          RowBox[{
           RowBox[{"ell", "[", 
            RowBox[{"3", ",", "1"}], "]"}], "+", "pp2", "-", "qq1"}]}], ";", 
         "\n", 
         RowBox[{
          RowBox[{"ell", "[", 
           RowBox[{"2", ",", "1"}], "]"}], "=", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"ell", "[", 
             RowBox[{"3", ",", "1"}], "]"}]}], "+", "qq1"}]}], ";", "\n", 
         RowBox[{
          RowBox[{"ell", "[", 
           RowBox[{"3", ",", "2"}], "]"}], "=", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"ell", "[", 
             RowBox[{"3", ",", "1"}], "]"}]}], "+", "pp3"}]}], ";", "\n", 
         RowBox[{
          RowBox[{"ell", "[", 
           RowBox[{"1", ",", "3"}], "]"}], "=", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"ell", "[", 
             RowBox[{"3", ",", "1"}], "]"}]}], "+", "pp1", "+", "pp3", "-", 
           "qq2"}]}], ";", "\n", 
         RowBox[{"Return", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"ell", "[", 
             RowBox[{"1", ",", "2"}], "]"}], ",", 
            RowBox[{"ell", "[", 
             RowBox[{"2", ",", "3"}], "]"}], ",", 
            RowBox[{"ell", "[", 
