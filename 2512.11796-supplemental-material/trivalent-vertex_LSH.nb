       RowBox[{"n", " ", 
        RowBox[{"times", "."}]}]}], " ", "*)"}], "\n", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"n", ">=", "0"}], ",", "\n", 
        RowBox[{
         RowBox[{"result", "=", "state"}], ";", "\n", 
         RowBox[{"Do", "[", 
          RowBox[{
           RowBox[{"result", "=", 
            RowBox[{"StateConsolidateTerms", "[", 
             RowBox[{"f", "[", "result", "]"}], "]"}]}], ",", "n"}], "]"}], 
         ";", "\n", 
         RowBox[{"Return", "[", "result", "]"}], ";"}], "\n", ",", "\n", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<undefined operator power: \>\"", "<>", 
           RowBox[{"ToString", "[", "n", "]"}]}], "]"}], ";", "\n", 
         RowBox[{"Return", "[", "Null", "]"}], ";"}]}], "\n", "]"}], ";"}]}], 
    "\n", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"StateApplyOp", "[", 
     RowBox[{"f_", ",", "n_"}], "]"}], ":=", 
