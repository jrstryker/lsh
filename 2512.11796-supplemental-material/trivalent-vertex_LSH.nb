Cell["\<\
Define a seventh Casimir operator, CT, and its matrix representation.\
\>", "Text",
 CellChangeTimes->{{3.974793103548984*^9, 3.974793122853414*^9}, {
  3.974793395778542*^9, 
  3.974793401562072*^9}},ExpressionUUID->"572b15d8-aa14-42cb-9962-\
959986e69102"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"StateCT", "[", "state_", "]"}], ":=", 
   RowBox[{"StateTADag", "[", 
    RowBox[{"StateTBDag", "[", 
     RowBox[{"StateTA", "[", 
      RowBox[{"StateTB", "[", "state", "]"}], "]"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SectorGetCTMatrixRep", "[", "PQPQPQ_", "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "sectorDim", ",", "basisStates", ",", "CTOnBasisStates", ",", 
       "basisTermQNums"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"sectorDim", "=", 
       RowBox[{"PQSectorDim", "[", "PQPQPQ", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"basisStates", "=", 
       RowBox[{"SectorGetBasisStates", "[", "PQPQPQ", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"CTOnBasisStates", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"StateCT", "[", 
          RowBox[{"basisStates", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "sectorDim"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"basisTermQNums", "=", 
       RowBox[{"SectorGetBasisTermQNums", "[", "PQPQPQ", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"StateGetAmplitude", "[", 
          RowBox[{
           RowBox[{"basisTermQNums", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", 
           RowBox[{"CTOnBasisStates", "[", 
            RowBox[{"[", "j", "]"}], "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "sectorDim"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "sectorDim"}], "}"}]}], "]"}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.974781857737999*^9, 3.974781911201563*^9}, {
   3.974782004556849*^9, 3.974782061030947*^9}, 3.974782093858576*^9, {
   3.974782139372602*^9, 3.974782176027935*^9}, {3.974782668353352*^9, 
   3.974782701922521*^9}, {3.974782736171096*^9, 3.974782935475883*^9}},
 CellLabel->
  "In[1338]:=",ExpressionUUID->"6311f516-0401-49ad-a31b-b76fbfa9765a"],

