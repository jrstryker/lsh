            RowBox[{"ell", "[", 
             RowBox[{"2", ",", "1"}], "]"}], ",", 
            RowBox[{"ell", "[", 
             RowBox[{"3", ",", "2"}], "]"}], ",", 
            RowBox[{"ell", "[", 
             RowBox[{"1", ",", "3"}], "]"}], ",", "tt"}], "}"}], "]"}], 
