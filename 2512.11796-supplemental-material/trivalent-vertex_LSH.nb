   RowBox[{
    RowBox[{
    "\\\\", " ", "2", "\n", " ", "\\\\", "\n", "  ", "\\\\", "\n", "   ", 
     "\\\\"}], "\n", "      ", "===", "===", "==="}], "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
