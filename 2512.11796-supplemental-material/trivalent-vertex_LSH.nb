     RowBox[{"StateCommutator", "[", 
      RowBox[{"f1", ",", "f2", ",", "#"}], "]"}], "&"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
