 RowBox[{
  RowBox[{"pqpqpqList", "=", 
   RowBox[{"{", "\n", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "1", ",", "1", ",", "1", ",", "1", ",", "1"}], "}"}], 
     ",", "\n", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "2", ",", "1", ",", "2", ",", "1"}], "}"}], 
     ",", "\n", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "1", ",", "2", ",", "1", ",", "1"}], "}"}], 
     ",", "\n", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "2", ",", "2", ",", "1", ",", "2"}], "}"}], 
     ",", "\n", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2", ",", "2", ",", "2", ",", "2", ",", "2"}], "}"}], 
     ",", "\n", 
     RowBox[{"{", 
      RowBox[{"3", ",", "2", ",", "2", ",", "3", ",", "2", ",", "2"}], "}"}], 
     ",", "\n", 
     RowBox[{"{", 
      RowBox[{"3", ",", "2", ",", "3", ",", "3", ",", "2", ",", "3"}], "}"}], 
     ",", "\n", 
     RowBox[{"{", 
      RowBox[{"3", ",", "3", ",", "3", ",", "3", ",", "3", ",", "3"}], "}"}], 
     ",", "\n", 
     RowBox[{"{", 
      RowBox[{"4", ",", "3", ",", "3", ",", "4", ",", "3", ",", "3"}], 
      "}"}]}], "\n", "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.974769443943875*^9, 3.974769445007494*^9}, {
